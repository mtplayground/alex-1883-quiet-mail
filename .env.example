# Server
HOST=0.0.0.0
PORT=8080
FRONTEND_DIST=frontend/dist
SELF_URL=https://example.mctai.app

# PostgreSQL
DATABASE_URL=postgresql://app_user:app_password@example-postgres.internal:5432/app_database?sslmode=require
DATABASE_MAX_CONNECTIONS=5

# Ideavibes auth service
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_example_token
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Ideavibes email service
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=email_example_token

# Future single-account bootstrap support
SINGLE_ACCOUNT_EMAIL=user@example.com
SINGLE_ACCOUNT_PASSWORD=change-me-in-production

# Legacy compatibility only; new auth should verify the mctai_session cookie instead.
JWT_SECRET=legacy-example-secret

# E2E tests only. Never enable this in production.
# E2E_TEST_AUTH=true
# E2E_TEST_AUTH_EMAIL=e2e@example.com
# E2E_TEST_AUTH_NAME=E2E Tester
